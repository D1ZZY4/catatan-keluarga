{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "app.config.ts",
    "expo-entry.js",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
